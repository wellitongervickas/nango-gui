{
  "name": "nango-gui-workspace",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n renderer,electron -c cyan,magenta \"pnpm --filter '@nango-gui/renderer' dev\" \"pnpm --filter '@nango-gui/desktop' dev\"",
    "build": "pnpm --filter '@nango-gui/renderer' build && pnpm --filter '@nango-gui/desktop' build:main",
    "test": "vitest run",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "typecheck": "tsc --build"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ]
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "concurrently": "^9.1.2",
    "eslint": "^9.26.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.2",
    "typescript": "~5.8.3",
    "vitest": "^3.2.0"
  }
}
