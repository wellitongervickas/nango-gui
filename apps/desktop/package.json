{
  "name": "@nango-gui/desktop",
  "private": true,
  "version": "0.1.0",
  "main": "dist/main.js",
  "scripts": {
    "build:main": "tsup",
    "dev": "pnpm build:main && wait-on tcp:5173 && cross-env NODE_ENV=development electron dist/main.js",
    "build": "pnpm build:main",
    "pack": "electron-builder --dir -c electron-builder.json",
    "dist": "electron-builder -c electron-builder.json",
    "dist:mac": "electron-builder --mac -c electron-builder.json",
    "dist:win": "electron-builder --win -c electron-builder.json",
    "dist:linux": "electron-builder --linux -c electron-builder.json"
  },
  "dependencies": {
    "@nango-gui/main": "workspace:*",
    "@nango-gui/shared": "workspace:*",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "cross-env": "^7.0.3",
    "electron": "35.7.5",
    "electron-builder": "^25.1.8",
    "tsup": "^8.4.0",
    "typescript": "~5.8.3",
    "wait-on": "^8.0.3"
  }
}
